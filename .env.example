# MEXC API
MEXC_API_KEY=YOUR_API_KEY_HERE
MEXC_SECRET_KEY=YOUR_SECRET_KEY_HERE

# Multiple MEXC Futures symbols
# Add or remove coins here.
SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,XRP/USDT:USDT,BNB/USDT:USDT

# Strategy timeframes
TIMEFRAMES=1h,2h

# Risk settings
RISK_PERCENT=5
RISK_REWARD=3
BREAK_EVEN_R=0.82
LEVERAGE=1

# Keep true while testing. Set false only when ready for live trading.
DRY_RUN=true

# How often Railway checks the market
CHECK_INTERVAL_SECONDS=60
