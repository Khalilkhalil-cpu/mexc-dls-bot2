# Copy this file to .env for local testing.
# On Railway, add these in Project > Variables instead.

MEXC_API_KEY=YOUR_API_KEY_HERE
MEXC_SECRET_KEY=YOUR_SECRET_KEY_HERE

# MEXC USDT perpetual format used by ccxt, examples:
# BTC/USDT:USDT
# ETH/USDT:USDT
SYMBOL=BTC/USDT:USDT

# Your DLS strategy only works on 1H and 2H
TIMEFRAMES=1h,2h

# Risk settings
RISK_PERCENT=5
RISK_REWARD=3
BREAK_EVEN_R=0.82
LEVERAGE=1

# Safety: keep true until you have tested logs. Set false only when ready for live trading.
DRY_RUN=true

# Bot loop seconds. 60 is fine because it only enters after new closed candles.
POLL_SECONDS=60
